# Tripadvisor crawler
TA_BASE_URL=https://www.tripadvisor.com
TA_ACCEPT_LANGUAGE=en-US,en;q=0.9
TA_PROXIES=
TA_DETAIL_CONCURRENCY=4
TA_GRAPHQL_CONCURRENCY=4
TA_IMAGE_CONCURRENCY=32
TA_IMAGE_REQUESTS_PER_SECOND=32
TA_IMAGE_REQUEST_JITTER_SECONDS=0
TA_IMAGE_USE_PROXY=false
TA_R2_CONCURRENCY=50
TA_REQUESTS_PER_SECOND=1.0
TA_REQUEST_JITTER_SECONDS=0.3
TA_MAX_RETRIES=3
TA_TIMEOUT_SECONDS=30
TA_GALLERY_QUERY_ID=e451fc43b6a61cab
TA_LOCALE=en-US
TA_TIMEZONE=America/New_York
TA_HEADLESS=true
TA_REAL_CHROME=false
TA_DISABLE_RESOURCES=false
TA_HTML_BROWSER_FALLBACK=true
TA_BROWSER_USER_DATA_DIR=data/browser/tripadvisor
TA_BROWSER_STICKY_AFTER_BLOCK=true
TA_BROWSER_BLOCK_STATUSES=403,429,503

# VPS orchestration. DATA_ROOT holds raw/ data/ status/ state/ browser/ logs/.
# On the VPS this is /data/city_geo (a mounted volume in docker-compose).
DATA_ROOT=/data/city_geo
# Default worker process count for `run --parallel`; also the upper clamp.
TA_WORKER_COUNT=4

# Image quality. Always pull the largest available size from Tripadvisor.
# Raise lower if you want to cap disk usage, but this disables the largest variants.
TA_DOWNLOAD_SIDE=8000
TA_IMAGE_MAX_SIDE=8000
TA_IMAGE_MAX_BYTES=26214400
# Hard cap on images downloaded per geo. CLI --max-images-per-geo is clamped to this.
TA_MAX_IMAGES_PER_GEO=10000

# Cloudflare R2. Leave blank to disable upload.
R2_UPLOAD_ENABLED=false
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET=r2-qiqi
R2_PREFIX=qiqi
R2_REGION=auto
