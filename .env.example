# Tripadvisor crawler
TA_BASE_URL=https://www.tripadvisor.com
TA_ACCEPT_LANGUAGE=en-US,en;q=0.9
TA_PROXIES=
TA_DETAIL_CONCURRENCY=4
TA_GRAPHQL_CONCURRENCY=4
TA_IMAGE_CONCURRENCY=16
TA_R2_CONCURRENCY=16
TA_REQUESTS_PER_SECOND=1.0
TA_REQUEST_JITTER_SECONDS=0.3
TA_MAX_RETRIES=3
TA_TIMEOUT_SECONDS=30
TA_GALLERY_QUERY_ID=e451fc43b6a61cab
TA_LOCALE=en-US
TA_TIMEZONE=America/New_York
TA_HEADLESS=true
TA_REAL_CHROME=false
TA_DISABLE_RESOURCES=false

# Cloudflare R2. Leave blank to disable upload.
R2_UPLOAD_ENABLED=false
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET=r2-qiqi
R2_PREFIX=qiqi
R2_REGION=auto
